# Nusxa oling: cp .env.example .env  (Windows: copy .env.example .env)

# --- PostgreSQL ---
POSTGRES_USER=normavault
POSTGRES_PASSWORD=normavault
POSTGRES_DB=normavault
# Port 5433: hostda 5432 band bo'lsa (masalan lokal Windows PostgreSQL xizmati) shu portdan foydalaning
# DATABASE_URL — jadval egasi (faqat migratsiya/seed uchun, prisma migrate shu orqali ishlaydi)
DATABASE_URL=postgresql://normavault:normavault@localhost:5433/normavault
# APP_DATABASE_URL — runtime (api/worker) shu orqali ulanadi: egasi emas, shuning uchun
# audit_logs'dagi UPDATE/DELETE REVOKE haqiqatan kuchga ega (CLAUDE.md 3-qoida).
# Rol/parol qo'lda SQL migratsiyada yaratiladi (packages/db/prisma/migrations/*_unsupported_indexes_and_locks).
APP_DATABASE_URL=postgresql://normavault_app:normavault_app@localhost:5433/normavault

# --- Redis / BullMQ ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- MinIO (S3) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=normavault
S3_SECRET_KEY=normavault-secret
S3_BUCKET=normavault
S3_REGION=us-east-1

# --- SMTP (lokalda Mailpit) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=no-reply@normavault.local

# --- API ---
API_PORT=3001
WEB_ORIGIN=http://localhost:3000
JWT_ACCESS_SECRET=dev-access-secret-almashtiring
JWT_REFRESH_SECRET=dev-refresh-secret-almashtiring

# --- Web ---
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
