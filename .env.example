# Nusxa oling: cp .env.example .env  (Windows: copy .env.example .env)

# --- PostgreSQL ---
POSTGRES_USER=normavault
POSTGRES_PASSWORD=normavault
POSTGRES_DB=normavault
DATABASE_URL=postgresql://normavault:normavault@localhost:5432/normavault

# --- Redis / BullMQ ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- MinIO (S3) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=normavault
S3_SECRET_KEY=normavault-secret
S3_BUCKET=normavault
S3_REGION=us-east-1

# --- SMTP (lokalda Mailpit) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=no-reply@normavault.local

# --- API ---
API_PORT=3001
WEB_ORIGIN=http://localhost:3000
JWT_ACCESS_SECRET=dev-access-secret-almashtiring
JWT_REFRESH_SECRET=dev-refresh-secret-almashtiring

# --- Web ---
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
