{
  "name": "@docmax/db",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "lint": "eslint src",
    "test": "dotenv -e ../../.env -- vitest run --passWithNoTests"
  },
  "dependencies": {
    "@docmax/shared": "workspace:*",
    "@prisma/client": "^6.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "argon2": "^0.41.0",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.0.0",
    "prisma": "^6.6.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.30.0",
    "vitest": "^3.1.0"
  }
}
